  "glossary": {
    "OBP": "On-Base Percentage — how often a batter reaches base safely (hits + walks + HBP divided by plate appearances)",
    "SLG": "Slugging Percentage — total bases divided by at-bats, measuring raw power output",
    "OPS": "On-base Plus Slugging — OBP + SLG combined, a quick measure of overall offensive production",
    "WHIP": "Walks + Hits per Inning Pitched — a measure of how many baserunners a pitcher allows",
    "OVR": "Overall rating — a weighted composite of key attributes for a player's position",
    "WAR": "Wins Above Replacement — how many wins a player adds compared to a replacement-level player",
    "ERA": "Earned Run Average — average earned runs allowed per 9 innings pitched",
    "FIP": "Fielding Independent Pitching — evaluates pitcher skill independent of defense behind them",
    "BABIP": "Batting Average on Balls In Play — batting average excluding home runs and strikeouts",
    "wRC+": "Weighted Runs Created Plus — park-adjusted offensive value where 100 is league average",
    "K%": "Strikeout Rate — percentage of plate appearances that end in a strikeout",
    "BB%": "Walk Rate — percentage of plate appearances that end in a walk",
    "HR/9": "Home Runs per 9 Innings — rate of home runs allowed by a pitcher",
    "IL": "Injured List — where players go when they are too injured to play",
    "DFA": "Designated for Assignment — removing a player from the 40-man roster",
    "MiLB": "Minor League Baseball — the farm system levels below the majors",
    "IFA": "International Free Agent — amateur players signed from outside the US/Canada draft system",
    "Arb": "Arbitration — salary negotiation process for players with 3-6 years of service time",
    "FA": "Free Agent — a player not under contract who can sign with any team",
    "DH": "Designated Hitter — a lineup spot that bats but does not play defense"
  }
}
